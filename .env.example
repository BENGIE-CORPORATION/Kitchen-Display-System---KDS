# ══════════════════════════════════════════════════════════════
#  .env.example — Variables raíz para docker-compose.prod.yml
#
#  Copia este archivo a .env y ajusta los valores:
#    cp .env.example .env
#
#  Las variables de Supabase y SECRET_KEY van en:
#    Backend/.env.production   (usa Backend/.env.production.example como base)
# ══════════════════════════════════════════════════════════════

# ── Dominios ──────────────────────────────────────────────────
# Caddy usa estas variables para configurar el reverse proxy y SSL.
# El DNS de ambos dominios debe apuntar a la IP del servidor antes de hacer prod-up.

# Dominio principal — sirve el frontend Flutter
DOMAIN=tudominio.com

# Subdominio de la API — sirve el backend FastAPI
API_DOMAIN=api.tudominio.com

# ── URL del backend para el build del frontend ────────────────
# Flutter compila la URL del backend dentro del JavaScript.
# Debe coincidir con API_DOMAIN con protocolo https.
PROD_API_URL=https://api.tudominio.com

# ── Grafana (producción) ──────────────────────────────────────
# Credenciales del panel de Grafana en producción.
# Se accede via SSH tunnel: ssh -L 3001:localhost:3000 user@servidor
GRAFANA_USER=admin
GRAFANA_PASSWORD=cambia-esto-en-prod
