# ══════════════════════════════════════════════════════════════
#  .env.example — Variables para docker-compose.prod.yml
#
#  Copia este archivo a .env y ajusta los valores:
#    cp .env.example .env
#
#  Este archivo solo contiene variables que docker-compose.prod.yml
#  necesita a nivel de raíz (no las del backend).
#  Las variables de Supabase van en Backend/.env.production
# ══════════════════════════════════════════════════════════════

# URL pública del backend en producción.
# El frontend Flutter se compila con esta URL baked en el JS.
# Si el frontend y backend están en el mismo host: http://IP_DEL_SERVIDOR:8000
# Con dominio:                                    https://api.tudominio.com
PROD_API_URL=http://localhost:8000
